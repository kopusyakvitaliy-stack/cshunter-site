/* ===== VARIABLES ===== */
:root {
  --bg:         #09090b;
  --bg-2:       #0f1014;
  --bg-3:       #16181f;
  --surface:    #1a1d27;
  --surface-2:  #22263a;
  --border:     rgba(255,255,255,0.06);
  --border-2:   rgba(255,255,255,0.1);
  --accent:     #F0C430;
  --accent-2:   #FFD700;
  --accent-dim: rgba(240,196,48,0.12);
  --accent-glow:0 0 24px rgba(240,196,48,0.35);
  --green:      #4ADE80;
  --red:        #F87171;
  --text:       #FFFFFF;
  --text-2:     #A8ABBE;
  --text-3:     #555870;
  --radius:     14px;
  --radius-sm:  8px;
  --sidebar-w:  200px;
  --header-h:   56px;
  --transition: 0.22s cubic-bezier(0.4,0,0.2,1);
}

/* ===== RESET ===== */
*, *::before, *::after { margin:0; padding:0; box-sizing:border-box; }
html { scroll-behavior:smooth; }

/* ===== GLOBAL FONT OVERRIDE ===== */
*, *::before, *::after {
  font-family: 'Manrope', sans-serif;
}
h1, h2, h3, h4, h5, h6,
h1 span, h2 span, h3 span,
.logo-text, .logo-cs, .logo-hunter,
.mode-card-name, .mode-tile-name,
.stat-value, .stat-block .stat-value,
.hero-stat-num, .hero-stat-card-num,
.mode-hero-title-new, .rt-title, .rt-time-big,
.faceit-stat-num, .rt-hero-title, .rt-hero-title span,
.rt-fact-num, .rt-lb-ms, .rt-history-ms,
.modal-title, .connect-address,
.mode-hero-title, .mode-tile-name,
.home-hero-left h1, .home-hero-left h1 span, .home-stat-num,
.rt-info-card-title, .rt-info-card-title span,
[class*="barlow"], .sc-title, .page-title {
  font-family: 'Unbounded', sans-serif;
}

body {
  background: var(--bg);
  color: var(--text);
  font-family: 'Manrope', sans-serif;
  font-size: 15px;
  line-height: 1.6;
  min-height: 100vh;
  overflow-x: hidden;
  -webkit-font-smoothing: antialiased;
}

a { text-decoration:none; color:inherit; }
img { max-width:100%; display:block; }
button { font-family:'Manrope',sans-serif; cursor:pointer; }

/* ===== SCROLLBAR ===== */
::-webkit-scrollbar { width:5px; height:5px; }
::-webkit-scrollbar-track { background:var(--bg-2); }
::-webkit-scrollbar-thumb { background:var(--surface-2); border-radius:3px; }
::-webkit-scrollbar-thumb:hover { background:var(--border-2); }

/* ===== LAYOUT ===== */
.layout { display:flex; min-height:100vh; }

/* ===== SIDEBAR ===== */
.sidebar {
  width: var(--sidebar-w);
  background: var(--bg-2);
  display: flex;
  flex-direction: column;
  position: fixed;
  top: 0; left: 0;
  height: 100vh;
  z-index: 200;
  overflow-y: auto;
  overflow-x: hidden;
}

.sidebar-logo {
  padding: 16px 24px 14px;
}

.logo-link {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6px;
  text-decoration: none;
}

.logo-img {
  height: 108px;
  width: auto;
  display: block;
  filter: invert(1) sepia(1) saturate(6) hue-rotate(2deg) brightness(1.05);
  transition: filter 0.2s ease, transform 0.2s ease;
}

.logo-link:hover .logo-img {
  filter: invert(1) sepia(1) saturate(8) hue-rotate(2deg) brightness(1.15);
  transform: scale(1.04);
}

.logo-text {
  font-family: 'Unbounded', sans-serif;
  font-size: 30px;
  font-weight: 900;
  letter-spacing: 3px;
  text-transform: uppercase;
  line-height: 1;
}

.logo-cs { color: var(--accent); }
.logo-hunter { color: var(--text); }

.logo-tagline {
  font-size: 9px;
  letter-spacing: 2.5px;
  text-transform: uppercase;
  color: var(--text-3);
  font-weight: 600;
  text-align: center;
}

.nav-section { padding: 14px; flex: 1; }

.nav-label {
  font-family: 'Manrope', sans-serif;
  font-size: 10px;
  letter-spacing: 1.8px;
  text-transform: uppercase;
  color: var(--text-3);
  padding: 14px 10px 6px;
  font-weight: 700;
}

.nav-item {
  font-family: 'Manrope', sans-serif;
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 12px 16px;
  border-radius: var(--radius-sm);
  color: var(--text-2);
  font-size: 14px;
  font-weight: 600;
  transition: all var(--transition);
  position: relative;
  overflow: hidden;
}

.nav-item::before {
  content: '';
  position: absolute;
  left: 0; top: 50%;
  transform: translateY(-50%) scaleY(0);
  width: 3px; height: 55%;
  background: var(--accent);
  border-radius: 0 3px 3px 0;
  transition: transform var(--transition);
}

.nav-item:hover,
.nav-item.active {
  background: var(--accent-dim);
  color: var(--accent);
}

.nav-item.active::before,
.nav-item:hover::before {
  transform: translateY(-50%) scaleY(1);
}

.nav-icon {
  width: 20px; height: 20px;
  flex-shrink: 0;
  transition: opacity var(--transition);
  opacity: 0.6;
}

.nav-item:hover .nav-icon,
.nav-item.active .nav-icon { opacity: 1; }

.nav-badge {
  margin-left: auto;
  background: var(--accent);
  color: #000;
  font-size: 9px;
  font-weight: 900;
  letter-spacing: 1px;
  padding: 2px 6px;
  border-radius: 4px;
  text-transform: uppercase;
}

.sidebar-footer {
  padding: 16px 20px;
}

.online-strip {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 12px;
  color: var(--text-3);
  font-weight: 600;
}

.online-dot-sm {
  width: 7px; height: 7px;
  background: var(--green);
  border-radius: 50%;
  animation: pulse-dot 2.5s infinite;
  box-shadow: 0 0 6px var(--green);
}

@keyframes pulse-dot {
  0%,100%{ opacity:1; transform:scale(1); }
  50%{ opacity:.6; transform:scale(1.4); }
}

/* ===== MAIN AREA ===== */
.main {
  margin-left: var(--sidebar-w);
  flex: 1;
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  padding-top: var(--header-h);
}

/* ===== HEADER ===== */
.header {
  height: var(--header-h);
  background: var(--bg-2);
  backdrop-filter: none;
  -webkit-backdrop-filter: none;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 40px;
  position: fixed;
  top: 0;
  left: var(--sidebar-w);
  right: 0;
  z-index: 100;
}

.header-search {
  display: flex;
  align-items: center;
  gap: 10px;
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 10px;
  padding: 8px 14px;
  width: 320px;
  transition: border-color var(--transition), box-shadow var(--transition);
}

.header-search:focus-within {
  border-color: rgba(240,196,48,0.4);
  box-shadow: 0 0 0 3px rgba(240,196,48,0.07);
}

.header-search svg { color: var(--text-3); flex-shrink:0; }

.search-input {
  background: none;
  border: none;
  outline: none;
  color: var(--text);
  font-family: 'Manrope', sans-serif;
  font-size: 13px;
  font-weight: 600;
  width: 100%;
}

.search-input::placeholder { color: var(--text-3); }

.header-right { display:flex; align-items:center; gap:10px; }

/* Steam button */
.btn-steam {
  font-family: 'Manrope', sans-serif;
  display: flex;
  align-items: center;
  gap: 8px;
  background: var(--accent);
  color: #000;
  border: none;
  padding: 9px 20px;
  border-radius: var(--radius-sm);
  font-weight: 800;
  font-size: 13px;
  letter-spacing: 0.3px;
  transition: all var(--transition);
  white-space: nowrap;
}

.btn-steam:hover {
  background: var(--accent-2);
  transform: translateY(-1px);
  box-shadow: var(--accent-glow);
}

.btn-logout {
  font-family: 'Manrope', sans-serif;
  background: var(--surface);
  border: 1px solid var(--border);
  color: var(--text-3);
  padding: 8px 14px;
  border-radius: var(--radius-sm);
  font-size: 12px;
  font-weight: 700;
  transition: all var(--transition);
}

.btn-logout:hover {
  border-color: var(--red);
  color: var(--red);
}

/* User chip */
.user-chip {
  display: flex;
  align-items: center;
  gap: 9px;
  background: var(--surface);
  border: 1px solid var(--border);
  padding: 5px 14px 5px 7px;
  border-radius: 30px;
  transition: all var(--transition);
}

.user-chip:hover {
  border-color: rgba(240,196,48,0.4);
  background: var(--surface-2);
}

.user-chip-avatar {
  width: 30px; height: 30px;
  border-radius: 50%;
  background: var(--surface-2);
  object-fit: cover;
}

.user-chip-name {
  font-family: 'Manrope', sans-serif;
  font-size: 13px;
  font-weight: 700;
  max-width: 120px;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* ===== CONTENT ===== */
.content { padding: 32px 40px; flex:1; }

/* ===== ANIMATIONS ===== */
@keyframes fadeInUp {
  from { opacity:0; transform:translateY(18px); }
  to   { opacity:1; transform:translateY(0); }
}

@keyframes fadeIn {
  from { opacity:0; }
  to   { opacity:1; }
}

@keyframes shimmer {
  from { background-position: -200% center; }
  to   { background-position:  200% center; }
}

/* ===== PAGE HEADER ===== */
.page-header {
  margin-bottom: 24px;
  animation: fadeInUp .4s ease both;
}

.page-title {
  font-family: 'Unbounded', sans-serif;
  font-size: 38px;
  font-weight: 900;
  text-transform: uppercase;
  letter-spacing: 1.5px;
  line-height: 1;
  display: flex;
  align-items: center;
  gap: 14px;
}

.page-subtitle {
  color: var(--text-3);
  font-size: 14px;
  margin-top: 6px;
  font-weight: 600;
}

/* ===== STATS STRIP ===== */
.stats-strip {
  display: flex;
  gap: 2px;
  margin-bottom: 28px;
  border-radius: var(--radius);
  overflow: hidden;
  animation: fadeInUp .4s ease .05s both;
}

.stat-block {
  flex: 1;
  background: var(--surface);
  border: 1px solid var(--border);
  padding: 22px 24px;
  text-align: center;
  position: relative;
  overflow: hidden;
  transition: background var(--transition);
}

.stat-block:hover { background: var(--surface-2); }

.stat-block::after {
  content:'';
  position:absolute;
  bottom:0; left:50%;
  transform:translateX(-50%);
  width:30px; height:2px;
  background: var(--accent);
  border-radius:2px 2px 0 0;
  opacity:0;
  transition:opacity var(--transition);
}

.stat-block:hover::after { opacity:1; }

.stat-value {
  font-family: 'Unbounded', sans-serif;
  font-size: 30px;
  font-weight: 900;
  color: var(--accent);
  line-height: 1;
}

.stat-label {
  font-family: 'Manrope', sans-serif;
  font-size: 10px;
  color: var(--text-3);
  text-transform: uppercase;
  letter-spacing: 2px;
  margin-top: 6px;
  font-weight: 700;
}

/* ===== MODE CARDS GRID ===== */
.modes-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
  gap: 22px;
}

/* MODE CARD */
.mode-card {
  border-radius: var(--radius);
  overflow: hidden;
  cursor: pointer;
  position: relative;
  aspect-ratio: 16/9;
  background: var(--surface);
  transition: transform .35s cubic-bezier(0.34, 1.56, 0.64, 1), box-shadow .35s ease;
  opacity: 0;
  animation: fadeInUp .5s ease forwards;
  will-change: transform;
}

.mode-card:nth-child(1){ animation-delay:.06s; }
.mode-card:nth-child(2){ animation-delay:.12s; }
.mode-card:nth-child(3){ animation-delay:.18s; }
.mode-card:nth-child(4){ animation-delay:.24s; }
.mode-card:nth-child(5){ animation-delay:.30s; }
.mode-card:nth-child(6){ animation-delay:.36s; }

.mode-card:hover {
  transform: translateY(-8px) scale(1.015);
  box-shadow: 0 24px 48px rgba(0,0,0,0.5), var(--accent-glow);
  z-index: 2;
}

.mode-card-bg {
  position: absolute; inset:0;
  background-size: cover;
  background-position: center;
  transition: transform .5s ease;
}

.mode-card:hover .mode-card-bg { transform: scale(1.06); }

.mode-card-overlay {
  position: absolute; inset:0;
  background: linear-gradient(160deg,
    rgba(0,0,0,0.1) 0%,
    rgba(0,0,0,0.35) 40%,
    rgba(0,0,0,0.85) 100%
  );
  transition: background .3s;
}

.mode-card:hover .mode-card-overlay {
  background: linear-gradient(160deg,
    rgba(0,0,0,0.15) 0%,
    rgba(0,0,0,0.4) 40%,
    rgba(0,0,0,0.92) 100%
  );
}

.mode-card-border {
  position:absolute; inset:0;
  border-radius: var(--radius);
  border: 2px solid var(--accent);
  opacity:0;
  transition: opacity .3s;
  pointer-events:none;
}

.mode-card:hover .mode-card-border { opacity:.7; }

.mode-card-content {
  position: absolute;
  bottom:0; left:0; right:0;
  padding: 24px;
}

.mode-card-tag {
  display: inline-block;
  background: var(--accent);
  color: #000;
  font-size: 10px;
  font-weight: 900;
  letter-spacing: 2px;
  text-transform: uppercase;
  padding: 4px 10px;
  border-radius: 5px;
  margin-bottom: 8px;
}

.mode-card-name {
  font-family: 'Unbounded', sans-serif;
  font-size: 38px;
  font-weight: 900;
  text-transform: uppercase;
  letter-spacing: 1px;
  line-height: 1;
  margin-bottom: 10px;
  text-shadow: 0 2px 14px rgba(0,0,0,0.6);
}

.mode-card-meta {
  display: flex;
  align-items: center;
  gap: 14px;
  font-size: 12px;
  color: rgba(255,255,255,0.65);
  font-weight: 600;
}

.meta-icon {
  display: flex;
  align-items: center;
  gap: 5px;
}

.meta-dot {
  width: 6px; height: 6px;
  background: var(--green);
  border-radius: 50%;
  box-shadow: 0 0 6px var(--green);
}

/* Arrow on hover */
.mode-card-arrow {
  position: absolute;
  top: 16px; right: 16px;
  width: 32px; height: 32px;
  background: rgba(240,196,48,0.15);
  border: 1px solid rgba(240,196,48,0.4);
  border-radius: 50%;
  display: flex; align-items:center; justify-content:center;
  opacity: 0;
  transform: translate(-4px,4px);
  transition: all .3s;
}

.mode-card:hover .mode-card-arrow {
  opacity:1;
  transform: translate(0,0);
}

/* ===== BREADCRUMB ===== */
.breadcrumb {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 14px;
  color: var(--text-3);
  margin-bottom: 24px;
  font-weight: 600;
  animation: fadeIn .3s ease;
}

.breadcrumb a { transition: color var(--transition); }
.breadcrumb a:hover { color: var(--accent); }
.breadcrumb-sep { color: var(--text-3); opacity:.4; }

/* ===== MODE PAGE HERO ===== */
.mode-hero {
  position: relative;
  height: 240px;
  border-radius: var(--radius);
  overflow: hidden;
  margin-bottom: 28px;
  animation: fadeInUp .4s ease both;
}

.mode-hero-bg {
  position: absolute; inset:0;
  background-size: cover;
  background-position: center;
  filter: blur(3px);
  transform: scale(1.06);
}

.mode-hero-overlay {
  position: absolute; inset:0;
  background: linear-gradient(100deg, rgba(0,0,0,.92) 0%, rgba(0,0,0,.6) 50%, rgba(0,0,0,.2) 100%);
}

.mode-hero-content {
  position: absolute;
  bottom: 0; left: 0; right:0;
  padding: 32px 40px;
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
}

.mode-hero-left {}

.mode-hero-tag {
  display: inline-block;
  background: var(--accent);
  color: #000;
  font-family: 'Manrope', sans-serif;
  font-size: 10px;
  font-weight: 800;
  letter-spacing: 2px;
  text-transform: uppercase;
  padding: 5px 12px;
  border-radius: 6px;
  margin-bottom: 10px;
}

.mode-hero-title {
  font-family: 'Unbounded', sans-serif;
  font-size: 52px;
  font-weight: 900;
  text-transform: uppercase;
  letter-spacing: 2px;
  line-height: 1;
}

.mode-hero-stats {
  display: flex;
  gap: 22px;
  font-size: 14px;
  color: rgba(255,255,255,.65);
  font-weight: 600;
  margin-top: 10px;
}

.mode-hero-right {
  display: flex;
  gap: 14px;
}

.hero-stat-box {
  background: rgba(255,255,255,.08);
  backdrop-filter: blur(10px);
  border: 1px solid rgba(255,255,255,.12);
  border-radius: var(--radius-sm);
  padding: 14px 24px;
  text-align: center;
}

.hero-stat-num {
  font-family: 'Unbounded', sans-serif;
  font-size: 34px;
  font-weight: 900;
  color: var(--accent);
}

.hero-stat-lbl {
  font-family: 'Manrope', sans-serif;
  font-size: 10px;
  color: rgba(255,255,255,.5);
  text-transform: uppercase;
  letter-spacing: 2px;
  font-weight: 700;
}

/* ===== MODE LAYOUT ===== */
.mode-columns {
  display: grid;
  grid-template-columns: 1fr 380px;
  gap: 28px;
}

/* ===== SECTION TITLE ===== */
.section-title {
  font-family: 'Manrope', sans-serif;
  font-size: 11px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 2px;
  margin-bottom: 14px;
  display: flex;
  align-items: center;
  gap: 10px;
  color: var(--text);
}

.section-title::after {
  content:'';
  flex:1;
  height:1px;
  background: var(--border);
}

.section-title .accent-dot {
  width: 6px; height: 6px;
  background: var(--accent);
  border-radius: 50%;
  box-shadow: 0 0 8px var(--accent);
  flex-shrink: 0;
}

/* ===== SERVER CARDS ===== */
.server-card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 16px 20px;
  display: flex;
  align-items: center;
  gap: 16px;
  margin-bottom: 10px;
  transition: all var(--transition);
  opacity: 0;
  animation: fadeInUp .4s ease forwards;
}

.server-card:nth-child(1){ animation-delay:.05s; }
.server-card:nth-child(2){ animation-delay:.1s; }
.server-card:nth-child(3){ animation-delay:.15s; }
.server-card:nth-child(4){ animation-delay:.2s; }

.server-card:hover {
  border-color: rgba(240,196,48,0.25);
  background: var(--surface-2);
  transform: translateX(5px);
  box-shadow: -4px 0 0 var(--accent), 0 4px 20px rgba(0,0,0,.3);
}

.server-status-dot {
  width: 9px; height: 9px;
  border-radius: 50%;
  background: var(--green);
  box-shadow: 0 0 10px var(--green);
  flex-shrink: 0;
}

.server-status-dot.offline {
  background: var(--red);
  box-shadow: 0 0 10px var(--red);
}

.server-info { flex:1; min-width:0; }

.server-name {
  font-family: 'Manrope', sans-serif;
  font-weight: 700;
  font-size: 15px;
  margin-bottom: 5px;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.server-meta {
  display: flex;
  gap: 12px;
  font-size: 12px;
  color: var(--text-3);
  font-weight: 600;
}

.server-map { color: var(--accent); }

.server-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 7px;
  flex-shrink: 0;
}

.server-players {
  font-family: 'Unbounded', sans-serif;
  font-size: 17px;
  font-weight: 700;
  color: var(--text-2);
  white-space: nowrap;
}

.players-bar {
  width: 90px; height: 3px;
  background: var(--bg);
  border-radius: 2px;
  overflow: hidden;
}

.players-bar-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--accent), #FF8C00);
  border-radius: 2px;
  transition: width 1.2s cubic-bezier(0.4,0,0.2,1);
}

.btn-connect {
  background: var(--accent);
  color: #000;
  border: none;
  padding: 9px 20px;
  border-radius: 8px;
  font-weight: 900;
  font-size: 13px;
  letter-spacing: 0.8px;
  text-transform: uppercase;
  transition: all var(--transition);
  white-space: nowrap;
}

.btn-connect:hover {
  background: var(--accent-2);
  transform: scale(1.05);
  box-shadow: 0 4px 16px rgba(240,196,48,.4);
}

/* ===== SIDEBAR CARDS (info/rules/top) ===== */
.info-card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 22px;
  margin-bottom: 16px;
  animation: fadeIn .5s ease both;
}

.info-card-title {
  font-family: 'Manrope', sans-serif;
  font-size: 11px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 2px;
  color: var(--accent);
  padding-bottom: 12px;
  margin-bottom: 14px;
  border-bottom: 1px solid var(--border);
  display: flex;
  align-items: center;
  gap: 8px;
}

.mode-description {
  font-size: 13px;
  color: var(--text-2);
  line-height: 1.7;
}

/* ===== RULES ===== */
.rules-list {
  list-style: none;
  counter-reset: rc;
}

.rules-list li {
  font-family: 'Manrope', sans-serif;
  counter-increment: rc;
  position: relative;
  padding: 9px 0 9px 28px;
  font-size: 13px;
  color: var(--text-2);
  line-height: 1.5;
  border-bottom: 1px solid var(--border);
}

.rules-list li:last-child { border-bottom:none; }

.rules-list li::before {
  content: counter(rc);
  position: absolute;
  left: 0; top: 50%;
  transform: translateY(-50%);
  width: 18px; height: 18px;
  background: var(--accent-dim);
  border: 1px solid rgba(240,196,48,.25);
  border-radius: 4px;
  font-size: 10px;
  font-weight: 900;
  color: var(--accent);
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: 'Unbounded', sans-serif;
}

/* ===== TOP PLAYERS ===== */
.player-row {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 9px 0;
  border-bottom: 1px solid var(--border);
  transition: background var(--transition);
  border-radius: var(--radius-sm);
}

.player-row:last-child { border-bottom:none; }

.player-rank {
  font-family: 'Unbounded', sans-serif;
  font-size: 22px;
  font-weight: 900;
  color: var(--text-3);
  width: 26px;
  text-align: center;
  flex-shrink: 0;
}

.player-rank.gold   { color: #FFD700; }
.player-rank.silver { color: #C0C0C0; }
.player-rank.bronze { color: #CD7F32; }

.player-avatar {
  width: 34px; height: 34px;
  border-radius: 50%;
  background: var(--surface-2);
  overflow: hidden;
  flex-shrink: 0;
  border: 2px solid var(--border);
}

.player-avatar img {
  width:100%; height:100%;
  object-fit: cover;
}

.player-avatar-placeholder {
  width:100%; height:100%;
  display:flex; align-items:center; justify-content:center;
  font-family:'Unbounded',sans-serif;
  font-size:16px; font-weight:900;
  color: var(--accent);
  background: var(--accent-dim);
}

.player-info { flex:1; min-width:0; }

.player-name {
  font-size: 13px;
  font-weight: 700;
  overflow:hidden;
  text-overflow:ellipsis;
  white-space:nowrap;
}

.player-playtime {
  font-size: 11px;
  color: var(--text-3);
  font-weight: 600;
}

.player-score {
  font-family: 'Unbounded', sans-serif;
  font-size: 20px;
  font-weight: 900;
  color: var(--accent);
  flex-shrink: 0;
}

/* ===== SKINCHANGER ===== */
.skin-tabs {
  display: flex;
  gap: 6px;
  margin-bottom: 20px;
  flex-wrap: wrap;
  animation: fadeInUp .4s ease .1s both;
}

.skin-tab {
  background: var(--surface);
  border: 1px solid var(--border);
  color: var(--text-3);
  padding: 8px 18px;
  border-radius: 30px;
  font-weight: 700;
  font-size: 13px;
  cursor: pointer;
  transition: all var(--transition);
}

.skin-tab:hover {
  border-color: var(--border-2);
  color: var(--text-2);
}

.skin-tab.active {
  background: var(--accent-dim);
  border-color: rgba(240,196,48,.4);
  color: var(--accent);
}

.skin-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(175px, 1fr));
  gap: 14px;
}

.skin-card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius-sm);
  overflow: hidden;
  cursor: pointer;
  transition: all var(--transition);
  opacity: 0;
  animation: fadeInUp .45s ease forwards;
  position: relative;
}

.skin-card:hover {
  border-color: rgba(240,196,48,.35);
  transform: translateY(-5px);
  box-shadow: 0 12px 32px rgba(0,0,0,.4), 0 0 0 1px rgba(240,196,48,.15);
}

.skin-card:nth-child(1){ animation-delay:.03s; }
.skin-card:nth-child(2){ animation-delay:.06s; }
.skin-card:nth-child(3){ animation-delay:.09s; }
.skin-card:nth-child(4){ animation-delay:.12s; }
.skin-card:nth-child(5){ animation-delay:.15s; }
.skin-card:nth-child(6){ animation-delay:.18s; }
.skin-card:nth-child(7){ animation-delay:.21s; }
.skin-card:nth-child(8){ animation-delay:.24s; }

.skin-img-wrap {
  aspect-ratio: 16/9;
  background: linear-gradient(135deg, var(--bg-3), var(--surface-2));
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 14px;
  position: relative;
  overflow: hidden;
}

.skin-img-wrap::before {
  content:'';
  position:absolute; inset:0;
  background: radial-gradient(circle at 70% 30%, rgba(240,196,48,.06) 0%, transparent 60%);
}

.skin-img-wrap img {
  width: 90%;
  object-fit: contain;
  filter: drop-shadow(0 6px 16px rgba(0,0,0,.6));
  transition: transform var(--transition);
}

.skin-card:hover .skin-img-wrap img {
  transform: scale(1.08) rotate(-2deg);
}

.skin-info {
  padding: 10px 12px 12px;
}

.skin-name {
  font-size: 12px;
  font-weight: 800;
  margin-bottom: 3px;
  overflow:hidden;
  text-overflow:ellipsis;
  white-space:nowrap;
}

.skin-weapon {
  font-size: 11px;
  color: var(--text-3);
  font-weight: 600;
}

.skin-rarity-bar {
  height: 2px;
  margin-top: 8px;
  border-radius: 2px;
}

.rarity-gold    { background: linear-gradient(90deg, #FFD700, #FF8C00); }
.rarity-red     { background: linear-gradient(90deg, #FF4444, #FF0000); }
.rarity-purple  { background: linear-gradient(90deg, #9B59B6, #6C3483); }
.rarity-blue    { background: linear-gradient(90deg, #3498DB, #1A6FBF); }
.rarity-green   { background: linear-gradient(90deg, #2ECC71, #1A7A44); }

.skin-apply-btn {
  position: absolute;
  top: 8px; right: 8px;
  background: var(--accent);
  color: #000;
  border: none;
  border-radius: 6px;
  padding: 4px 10px;
  font-size: 11px;
  font-weight: 900;
  opacity: 0;
  transform: translateY(-4px);
  transition: all var(--transition);
  letter-spacing:.5px;
  text-transform:uppercase;
}

.skin-card:hover .skin-apply-btn {
  opacity:1;
  transform:translateY(0);
}

/* ===== LOCKED (no steam login) ===== */
.lock-overlay {
  position:absolute; inset:0;
  background: rgba(9,9,11,.8);
  backdrop-filter: blur(4px);
  display:flex; flex-direction:column;
  align-items:center; justify-content:center;
  gap:10px;
  border-radius: var(--radius-sm);
  opacity:0;
  transition: opacity var(--transition);
}

.skin-card:hover .lock-overlay { opacity:1; }

.lock-text {
  font-size:12px;
  color:var(--text-2);
  font-weight:700;
  text-align:center;
  padding:0 10px;
}

/* ===== TOAST ===== */
.toast {
  position: fixed;
  bottom: 24px; right: 24px;
  background: var(--surface-2);
  border: 1px solid var(--border-2);
  border-left: 3px solid var(--accent);
  padding: 13px 18px;
  border-radius: var(--radius-sm);
  font-size: 13px;
  font-weight: 700;
  z-index: 9999;
  transform: translateX(130%);
  transition: transform .35s cubic-bezier(0.34, 1.56, 0.64, 1);
  max-width: 300px;
  box-shadow: 0 8px 32px rgba(0,0,0,.4);
  pointer-events:none;
  visibility: hidden;
}

.toast.show { transform: translateX(0); visibility: visible; }

/* ===== CONNECT MODAL ===== */
.modal-bg {
  position:fixed; inset:0;
  background: rgba(0,0,0,.7);
  backdrop-filter: blur(8px);
  z-index:500;
  display:flex; align-items:center; justify-content:center;
  opacity:0;
  pointer-events:none;
  transition: opacity .25s;
}

.modal-bg.open { opacity:1; pointer-events:all; }

.modal {
  background: var(--bg-3);
  border: 1px solid var(--border-2);
  border-radius: var(--radius);
  padding: 36px 40px;
  max-width: 460px;
  width: 90%;
  transform: translateY(20px) scale(.97);
  transition: transform .3s cubic-bezier(0.34, 1.56, 0.64, 1);
  box-shadow: 0 32px 80px rgba(0,0,0,.6);
}

.modal-bg.open .modal { transform: translateY(0) scale(1); }

.modal-title {
  font-family:'Unbounded',sans-serif;
  font-size:32px;
  font-weight:900;
  text-transform:uppercase;
  letter-spacing:1px;
  margin-bottom:6px;
}

.modal-sub {
  font-size:14px;
  color:var(--text-3);
  margin-bottom:24px;
  font-weight:600;
}

.connect-address {
  background:var(--bg-2);
  border:1px solid var(--border);
  border-radius:var(--radius-sm);
  padding:16px 20px;
  font-family:'Unbounded',sans-serif;
  font-size:26px;
  font-weight:700;
  color:var(--accent);
  letter-spacing:1px;
  margin-bottom:16px;
  text-align:center;
  user-select:all;
}

.modal-btns {
  display:flex;
  gap:12px;
}

.btn-primary {
  flex:1;
  background:var(--accent);
  color:#000;
  border:none;
  padding:14px;
  border-radius:var(--radius-sm);
  font-weight:900;
  font-size:15px;
  cursor:pointer;
  transition:all var(--transition);
  text-align:center;
}

.btn-secondary {
  flex:1;
  background: var(--surface-2);
  color: var(--text-2);
  border: 1px solid var(--border-2);
  padding:14px;
  border-radius:var(--radius-sm);
  font-weight:700;
  font-size:14px;
  cursor:pointer;
  transition:all var(--transition);
  font-family:'Manrope',sans-serif;
}
.btn-secondary:hover { background: var(--surface); border-color: var(--border); color: var(--text); }

.btn-primary:hover {
  background:var(--accent-2);
  box-shadow:var(--accent-glow);
}

.btn-secondary {
  background:var(--surface);
  border:1px solid var(--border);
  color:var(--text-2);
  padding:11px 18px;
  border-radius:var(--radius-sm);
  font-weight:700;
  font-size:14px;
  cursor:pointer;
  transition:all var(--transition);
}

.btn-secondary:hover {
  border-color:var(--border-2);
  color:var(--text);
}

/* ===== SECTION DESCRIPTION ===== */
.mode-desc-block {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius:var(--radius-sm);
  padding:18px 20px;
  margin-bottom:22px;
  font-size:14px;
  color:var(--text-2);
  line-height:1.7;
  animation: fadeInUp .4s ease .1s both;
}

/* ===== EMPTY STATE ===== */
.empty-state {
  text-align:center;
  padding:48px 20px;
  color:var(--text-3);
}

.empty-state-icon {
  font-size:48px;
  margin-bottom:12px;
}

/* ===== RESPONSIVE ===== */
@media (max-width: 1100px) {
  .mode-columns {
    grid-template-columns: 1fr;
  }
}

@media (max-width: 768px) {
  .sidebar { transform:translateX(-100%); }
  .main { margin-left:0; }
  .content { padding:16px; }
  .modes-grid { grid-template-columns:1fr; }
  .stats-strip { flex-direction:column; gap:2px; }
}

/* ===== MODAL PLAYER LIST SCROLLBAR ===== */
#playerList::-webkit-scrollbar { width: 4px; }
#playerList::-webkit-scrollbar-track { background: transparent; }
#playerList::-webkit-scrollbar-thumb { background: var(--surface-2); border-radius: 2px; }
#playerList::-webkit-scrollbar-thumb:hover { background: var(--border-2); }

/* Modal fixed width */
.modal { width: 420px !important; max-width: 95vw !important; }
