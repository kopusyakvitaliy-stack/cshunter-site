# Скопіюй цей файл в .env і заповни своїми даними:
#   cp .env.example .env

# ── Головна БД (cshunter) ─────────────────────────────────────
DB_HOST=127.0.0.1
DB_NAME=cshunter
DB_USER=cshunter_user
DB_PASS=

# ── Shared БД (скіни, плагіни) ────────────────────────────────
SHARED_DB_HOST=
SHARED_DB_NAME=s1_shared
SHARED_DB_USER=
SHARED_DB_PASS=

# ── API ключі ─────────────────────────────────────────────────
STEAM_API_KEY=
FACEIT_API_KEY=
PANDASCORE_KEY=

# ── Сайт ──────────────────────────────────────────────────────
SITE_URL=https://yourdomain.com
SITE_NAME=CSHunter
